# ============================================
# MOT — Environment Variables Template
# ============================================
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채워라.
# .env.local 은 절대 커밋하지 않는다. (.gitignore 처리됨)
#
# Sprint 0 (T2 이후) 에 다음이 채워져야 한다:
#   - NEXT_PUBLIC_SUPABASE_*  (3개)
#   - OPENAI_API_KEY
#   - NAVER_CLOVA_VOICE_*  (3개)
#   - DEVICE_AUTH_SECRET, CRON_SECRET (임의의 긴 문자열)
# ============================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_RESPONSE_MODEL=gpt-4o-mini
OPENAI_BATCH_MODEL=gpt-4o
OPENAI_STT_MODEL=whisper-1

# === 네이버 클로바보이스 ===
NAVER_CLOVA_VOICE_CLIENT_ID=
NAVER_CLOVA_VOICE_CLIENT_SECRET=
# voice_id 후보: vara / nshin / nara / nminyoung / ...
# Sprint 0~1 중 어떤 보이스가 캐릭터에 맞는지 사용자(이지형)가 결정.
NAVER_CLOVA_VOICE_VOICE_ID=vara

# === 카카오 알림톡 (Phase 1.5+) ===
KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

# === 토스페이먼츠 (Phase 2+) ===
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# === Cogno (Phase 2+) ===
COGNO_BASE_URL=
COGNO_API_KEY=
COGNO_MODEL=qwen3.6:35b

# === App / Auth / Cron ===
# 디바이스 토큰 서명용. 32자 이상 임의 문자열.
DEVICE_AUTH_SECRET=
# Vercel Cron 인증용. 16자 이상.
CRON_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
