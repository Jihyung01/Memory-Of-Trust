# =============================================
# MOT — Environment Variables
# =============================================
# 이 파일을 .env.local 로 복사하고 실제 키를 채우세요
# .env.local 은 절대 Git에 커밋하지 마세요

# -----------------------------------------
# Supabase
# -----------------------------------------
# 대시보드: https://supabase.com → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role 키는 절대 클라이언트 노출 금지 (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------
# OpenAI
# -----------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Realtime API 모델 (태블릿 실시간 대화용)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Responses API 모델 (후처리용)
OPENAI_RESPONSES_MODEL=gpt-4o

# 임베딩 모델
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------
# Kakao AlimTalk (선택 — Phase 3에서 필요)
# -----------------------------------------
# NHN Cloud 또는 Aligo 중 선택
KAKAO_PROVIDER=nhn_cloud
# 또는 KAKAO_PROVIDER=aligo

KAKAO_API_KEY=
KAKAO_API_SECRET=
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_CODE_DAILY_CARD=
KAKAO_TEMPLATE_CODE_RISK_ALERT=

# -----------------------------------------
# App Config
# -----------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MOT

# 크론 보안 (Vercel Cron 호출 검증용)
CRON_SECRET=generate-random-32-char-string

# -----------------------------------------
# Phase 2 (일단 비워둬도 됨)
# -----------------------------------------
# Twilio (v2 전화 방문 모드)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ElevenLabs (v2 고품질 TTS)
ELEVENLABS_API_KEY=
